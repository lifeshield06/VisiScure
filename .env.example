# HotelEase Environment Configuration
# Copy this file to .env and fill in your values

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=test

# Flask Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# SMS Configuration
# Set to 'true' to enable real SMS sending (production mode)
# Set to 'false' for development mode (OTP shown in console)
SMS_ENABLED=false

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30

